src/public/build/
src/public/hot

# Almacenamiento y cachés de Laravel (evita subir basura local)
src/storage/*.key
src/storage/logs/*
src/storage/framework/cache/*
src/storage/framework/sessions/*
src/storage/framework/views/*

# Infraestructura local (¡Ojo! NO incluimos dockerfiles/ aquí)
docker-compose.yml
docker-compose.yaml
mysql/
mysql_data/
postgres/
nginx/

